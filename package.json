{
  "name": "hearth",
  "version": "3.14.4",
  "private": true,
  "dependencies": {
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^3.4.0",
    "three": "^0.167.1"
  },
  "scripts": {
    "setup": "node scripts/setupFirebaseConfig.js",
    "predev": "node scripts/setupFirebaseConfig.js && node scripts/versioning.js generate",
    "prestart": "node scripts/setupFirebaseConfig.js && node scripts/versioning.js generate",
    "dev": "node scripts/startDevServers.js",
    "dev:frontend": "vite",
    "start": "vite",
    "start:apphosting": "node server/index.js",
    "template:media-map": "node scripts/generateTemplateMediaMap.mjs",
    "prebuild": "node scripts/setupFirebaseConfig.js --require-env && node scripts/versioning.js check && node scripts/versioning.js generate",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{js,jsx}\"",
    "lint:ci": "eslint \"src/**/*.{js,jsx}\" --max-warnings=0",
    "format": "prettier --write \"src/**/*.{js,jsx,css,json,md,html}\" \"public/**/*.{js,css,json,md,html}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css,json,md,html}\" \"public/**/*.{js,css,json,md,html}\"",
    "check:lockfile": "npm ci --dry-run",
    "test": "npm run test:unit && npm run test:api",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:api": "node --test api/__tests__/*.test.js",
    "prepare": "node scripts/installGitHooks.js"
  },
  "simple-git-hooks": {
    "pre-push": "npm run check:lockfile"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.23",
    "eslint": "^8.46.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^2.8.8",
    "sharp": "^0.32.3",
    "simple-git-hooks": "^2.11.1",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.1",
    "vitest": "^4.0.7",
    "jsdom": "^27.0.1",
    "web-streams-polyfill": "^4.2.0",
    "yaml": "^2.8.2"
  }
}
